newmem:
  // **** Begin Auto script: Multiplier
  // value=1, rule=R5_IntRead, template=P1_IntToFloat, NegDeltaCheck, FriendFoeFilter, PreserveXmm
  movaps [vf_xmm_bak0_457442], xmm15
  movaps [vf_xmm_bak1_457442], xmm14

code:
  // mov ecx,[rsi+0C]
  reassemble(INJECT_BATTLE_HP)
  test ecx, ecx
  jle short skip_mult_457442
  cmp edi, 0
  jg short skip_mult_457442

  mov [i_last_hp_addr], rsi
  // Multiplier: delta in ecx
  // ======== Friend/Foe Filter ========
  // Add your flag check here, e.g.:
  //   cmp dword ptr [rsi+OFFSET], FLAG_VALUE
  cmp dword ptr [rsi+2C], 0
  je short ff_foe_457442
  //   je ff_foe_457442
  // Default: all entities use friend multiplier
  // ====================================
  cmp dword ptr [i_min_hp], 0
  ja short @F

  mov eax,[rsi+10]
  vmovss xmm15, [vf_06]
  vcvtsi2ss xmm14, xmm14, eax
  vmulss xmm15, xmm14, xmm15
  vcvtss2si eax, xmm15
  mov [i_min_hp], eax

@@:

  vmovss xmm15, [vf_mult_friend_457442]
  cmp ecx, [i_min_hp]
  jae short ff_done_457442
  mov ecx, [i_min_hp]
  jmp short ff_done_457442
ff_foe_457442:
  vmovss xmm15, [vf_mult_foe_457442]
ff_done_457442:
  vcvtsi2ss xmm14, xmm14, edi
  vmulss xmm14, xmm14, xmm15
  vcvtss2si edi, xmm14

  cmp dword ptr [rsi+2C], 0
  je short @F
  add ecx, edi
  cmp ecx, [i_min_hp]
  jae short @F
  mov ecx, [i_min_hp]
  xor edi, edi

skip_mult_457442:
  movaps xmm15, [vf_xmm_bak0_457442]
  movaps xmm14, [vf_xmm_bak1_457442]
  // **** End Auto script: Multiplier

  // mov edx,[rsi+10]
  reassemble(INJECT_BATTLE_HP+3)
  jmp return
  align 10 cc
  vf_xmm_bak0_457442:
  dq 0
  dq 0
  vf_xmm_bak1_457442:
  dq 0
  dq 0
  vf_mult_friend_457442:
  dd (float)0.85
  vf_mult_foe_457442:
  dd (float)1.0
  i_last_hp_addr:
  dq 0
  i_min_hp:
  dd 0
  vf_06:
  dd (float)0.6

INJECT_BATTLE_HP:
  jmp newmem
  nop 1
return:
registersymbol(INJECT_BATTLE_HP INJECT_BATTLE_HPo vf_xmm_bak0_457442 vf_xmm_bak1_457442)
registersymbol(vf_mult_friend_457442 vf_mult_foe_457442)
registersymbol(i_last_hp_addr i_min_hp)

