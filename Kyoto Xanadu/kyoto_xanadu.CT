-- 任意の自動アタッチ補助：下のブロックのコメントを外すと先にゲームプロセスを開きます。

-- attach process
local processName = "kyoto_xanadu.exe"
local pid = getProcessIDFromProcessName(processName)
if pid ~= nil and pid &gt; 0 then
  local currentPid = getOpenedProcessID() or 0
  if currentPid ~= pid then
    openProcess(processName)
    print("Attached to: " .. processName)
    Sleep(333)
  else
    print("Already attached to: " .. processName)
  end
end
synchronize(function()
  getLuaEngine().Close()
end)


local function at_apply(list, active, stepMs)
  local al = getAddressList()
  for _, e in ipairs(list) do
    local mr = al.getMemoryRecordByID(e.id)
    if mr ~= nil and mr.Active ~= active then
      mr.Active = active
      if stepMs ~= nil and stepMs &gt; 0 then sleep(stepMs) end
    end
  end
  al.refresh()
end
synchronize(function() at_apply(enableList, true, CONFIG.stepDelayMs) end)
print("[AOBMaker] AA Toggle enabled.")
if CONFIG.closeLuaEngine then synchronize(function() getLuaEngine().Close() end) end
