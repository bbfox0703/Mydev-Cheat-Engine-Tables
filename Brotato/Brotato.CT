              <ShowAsSigned>1</ShowAsSigned>
              <VariableType>4 Bytes</VariableType>
              <Address>Reference_gold-30</Address>
            </CheatEntry>
            <CheatEntry>
              <ID>78</ID>
              <Description>"Reference.current_xp"</Description>
              <ShowAsSigned>1</ShowAsSigned>
              <VariableType>Double</VariableType>
              <Address>Reference_gold-18</Address>
            </CheatEntry>
            <CheatEntry>
              <ID>77</ID>
              <Description>"Reference.gold"</Description>
              <ShowAsSigned>1</ShowAsSigned>
              <VariableType>4 Bytes</VariableType>
              <Address>Reference_gold</Address>
            </CheatEntry>
