aobscanmodule(INJECT_INF_ARROW_N_OTHERS,$process,?? 83 ?? 10 00 7E ?? ?? 8D ?? 08 66 ?? FF ??)
// raw AOB: 0F B7 E8 66 41 3B C4 0F 8D ?? ?? ?? ?? 48 89 5C 24 50 BA FF FF 00 00 48 89 7C 24 58 66 44 3B 7E 12 0F 8D ?? ?? ?? ?? 0F BF C5 48 8D 1C 40 48 C1 E3 06 48 03 1E 48 39 1D ?? ?? ?? ?? 74 ?? 66 3B 53 08 74 ?? 48 83 7B 10 00 7E ?? 48 8D 4B 08 66 41 FF C7 E8 ?? ?? ?? ?? 48 8B C8 41 8B 45 00 39 01 75 ?? 83 7E 20 00 0F B7 43 08 74 ?? 44 8B 4E 20 33 C9 45 85 C9 74 ?? 4C 8B 56 18
// injection point AOB: ?? 83 ?? 10 00 7E ?? ?? 8D ?? 08 66 ?? FF ?? E8 ?? ?? ?? ?? ?? 8B ?? ?? 8B ?? 00 39 ?? 75 ?? 83 ?? 20 00 0F B7 ?? 08 74 ?? ?? 8B ?? 20 33 ?? ?? 85 ?? 74 ?? ?? 8B ?? 18
alloc(newmem,$1200)
// address capture
alloc(ptrList_arr_INJECT_7868_346234,$5DC0)
label(ptrList_count_INJECT_7868_346234)
label(i_item_qty_low i_item_qty_high i_item_id_low i_item_id_high)

alloc(INJECT_INF_ARROW_N_OTHERSo, $F)

label(code)
label(return)
label(is_chk_silver)
//label(check_silver)
//label(exc_loop)
//label(exc_found)
//label(exc_next)
//label(exc_done)
//label(rng_loop)
//label(rng_found)
//label(rng_next)
//label(rng_done)
//label(exception_table)
label(range_table is_set_min_mat)
label(i_abyss_cell_amt i_abyss_artifact_amt i_fabyss_artifact_amt i_atag_amt i_mac_resource_amt)
// ============================================================
//  查找優先順序:
//    1. 銀幣         → flag 控制，獨立判定
//    2. 例外表       → 最高優先，覆蓋區間
//    3. 區間表       → ID 落在區間內就套用
//    4. 都沒中       → 不修改，走原始邏輯
//
//  CE 數值: 無前綴 = hex，# 前綴 = 十進位
// ============================================================
//
//  例外表格式: dq &lt;item_id&gt;, &lt;amount&gt;   (每筆 0x10 = 16 bytes)
//  結尾標記:   dq -1, 0
//
//  區間表格式: dq &lt;start&gt;, &lt;end&gt;, &lt;amount&gt;, 0  (每筆 0x20 = 32 bytes)
//  結尾標記:   dq -1, 0, 0, 0
//
//  新增例外 → 插入 dq id, amount (保持 ID 升序)
//  新增區間 → 插入 dq start, end, amount, 0 (保持升序)
// ============================================================
INJECT_INF_ARROW_N_OTHERSo:
  readmem(INJECT_INF_ARROW_N_OTHERS, $F)

newmem:
  //cmp qword ptr [rbx+08], #6100 // item id must &lt;= 6300 (act. 60xx now)
  //ja skip_save_item
  // **** Begin Auto script: AddressCapture
  // mode=List, capacity=1000
  pushfq
  push r15
  push r14
  // Address Capture List
  mov r15, ptrList_arr_INJECT_7868_346234
  xor r14d, r14d
dedup_loop_346234:
  cmp r14d, [ptrList_count_INJECT_7868_346234]
  jge store_new_346234
  cmp [r15+r14*8], rbx
  je skip_store_346234
  inc r14d
  jmp dedup_loop_346234
store_new_346234:
  cmp r14d, #3000
  jge skip_store_346234
  mov [r15+r14*8], rbx
  inc dword ptr [ptrList_count_INJECT_7868_346234]
skip_store_346234:
  pop r14
  pop r15
  popfq
  // **** End Auto script: AddressCapture
skip_save_item:


  // --- 銅幣特殊處理  ---
  cmp dword ptr [rbx+8], #1770
  je check_silver


// ============================================================
//  第一步: 查例外表 (每筆 0x10, index r14 × 10)
// ============================================================
  push r15
  push r14
  push r13

  xor r14, r14
  mov r15, exception_table
exc_loop:
  lea r13, [r15+r14*1]         // r13 = exception_table + r14
  mov r13, [r13]               // r13 = entry item_id
  cmp r13, -1
  je short exc_done
  cmp r13d, [rbx+8]
  jne short exc_next
  // --- 命中例外 ---
  lea r13, [r15+r14*1]
  mov r13, [r13+8]             // r13 = amount
  mov [rbx+10], r13
  jmp short rng_done                 // 直接跳到結束
exc_next:
  add r14, 10                  // 下一筆 (0x10 = 16 bytes)
  jmp short exc_loop

rng_done:
  pop r13
  pop r14
  pop r15
  jmp code

exc_done:

  pop r13
  pop r14
  pop r15
  jmp range_check

// ============================================================
//  共用區間查找子程序
//  輸入:
//    r15 = 表格基址
//    r8b = 模式 (0 = 直接覆寫, 1 = min clamp)
//  讀取:
//    [rbx+8]  = item ID
//    [rbx+10] = 目前數量
//  輸出:
//    [rbx+10] 可能被修改
// ============================================================
range_lookup_sub:
  push r14
  push r13
  xor r14, r14
sub_loop:
  lea r13, [r15+r14*1]
  mov r13, [r13]               // r13 = range_start
  cmp r13, -1
  je sub_done
  cmp [rbx+8], r13d
  jb short sub_next
  lea r13, [r15+r14*1]
  mov r13, [r13+8]             // r13 = range_end
  cmp [rbx+8], r13d
  ja short sub_next
  // --- 命中區間 ---
  lea r13, [r15+r14*1]
  mov r13, [r13+10]            // r13 = amount
  test r8b, r8b
  jnz short sub_clamp
  mov [rbx+10], r13            // 模式 0: 直接覆寫
  jmp short sub_done
sub_clamp:
  cmp [rbx+10], r13            // 模式 1: 只在不足時補到最小值
  jae short sub_done
  mov [rbx+10], r13
  jmp short sub_done
sub_next:
  add r14, 20
  jmp sub_loop
sub_done:
  pop r13
  pop r14
  ret


// ============================================================
//  第二步: 查區間表 (覆寫模式)
// ============================================================
range_check:

  push r15
  push r8

  mov r15, range_table
  xor r8, r8                   // r8b = 0 → 直接覆寫
  call range_lookup_sub

  pop r8
  pop r15

// ============================================================
//  第三步: 查最小值區間表 (clamp 模式)
// ============================================================
check_min_amount:
  cmp dword ptr [is_set_min_mat], 1
  jne code

  push r15
  push r8

  mov r15, min_range_table
  mov r8b, 1                   // r8b = 1 → min clamp
  call range_lookup_sub

  pop r8
  pop r15
  jmp short code

check_silver:
  cmp dword ptr [is_chk_silver], 1
  jne short code
  cmp qword ptr [rbx+10], #98000
  ja short chk_silver_Lamt

  mov qword ptr [rbx+10], #98000
  jmp short code

chk_silver_Lamt:
  cmp qword ptr [rbx+10], #200000
  jbe short code
  mov qword ptr [rbx+10], #200000

code:
  // cmp qword ptr [rbx+10],00
  reassemble(INJECT_INF_ARROW_N_OTHERS)
  // jle CrimsonDesert.exe+1D39984
  reassemble(INJECT_INF_ARROW_N_OTHERS+5)
  // lea rcx,[rbx+08]
  reassemble(INJECT_INF_ARROW_N_OTHERS+7)
  // inc r15w
  reassemble(INJECT_INF_ARROW_N_OTHERS+B)
  jmp far return
  align 10 cc
  ptrList_count_INJECT_7868_346234:
  dd 0 0
  i_item_qty_low:
  dq 1
  i_item_qty_high:
  dq 2
  i_item_id_low:
  dq 1
  i_item_id_high:
