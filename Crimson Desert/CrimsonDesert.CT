  // lea esi,[rdi-01]
  reassemble(INJECT_OVERLOAD_GEAR_NO_DEC+C)
  jmp far return
  align 10 cc

INJECT_OVERLOAD_GEAR_NO_DEC:
  jmp far newmem
  nop 1
return:
