// ============================================================
//  區間表 (Range Table)
//  dq &lt;start&gt;, &lt;end&gt;, &lt;amount&gt;, 0   (每筆 0x20 bytes)
//  按起始 ID 升序排列
// ============================================================
align 20 cc

range_table:
dq #0,  #1,  #100, 0    // arrow
dq #3,  #9,  #100, 0    // arrow
dq #18,  #22,  #50, 0    // cannonball
dq #25,  #26,  #100, 0    // bullet
//dq #444,  #515,  #10, 0  // 傢俱
dq #1196, #1495, #20, 0  // 食物，馬料  1196=Dried Fish, 1197=Jerky 風乾肉塊, 1494=Sugar Beet, 1495=Sugar Cubes (1.05:1495)
