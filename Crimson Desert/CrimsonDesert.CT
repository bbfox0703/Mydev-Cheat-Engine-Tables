aobscanmodule(INJECT_ITEM_REMOVE_NO_DEC,$process,?? 29 ?? 02 10 ?? 8B ?? ?? 03 ?? ?? FF FF 00 00)
// raw AOB: E8 ?? ?? ?? ?? 0F B6 94 24 B8 01 00 00 48 8B C8 E8 ?? ?? ?? ?? 4C 8B D0 48 8B C5 48 99 49 F7 FA 45 33 C0 41 8B C8 48 85 D2 0F 95 C1 4C 8D 2C 01 49 8B 06 48 8B 8C 24 C8 01 00 00 48 8B 54 24 30 48 29 4C 02 10 49 8B 0E 48 03 CA B8 FF FF 00 00 66 3B 41 08 74 ?? 4C 39 41 10 7E ?? 48 8B 69 10 66 89 9C 24 A0 01 00 00 48 8D 8C 24 A0 01 00 00 E8 ?? ?? ?? ?? 0F B6 94 24 B8 01 00 00 48 8B C8 E8 ?? ?? ?? ?? 4C 8B D0 48 8B C5
// injection point AOB: ?? 29 ?? 02 10 ?? 8B ?? ?? 03 ?? ?? FF FF 00 00 66 3B ?? 08 74 ?? ?? 39 ?? 10 7E ?? ?? 8B ?? 10 66 89 ?? 24 ?? ?? 00 00 ?? 8D ?? 24 ?? ?? 00 00 E8 ?? ?? ?? ?? 0F B6 ?? 24 ?? ?? 00 00 ?? 8B ?? E8 ?? ?? ?? ?? ?? 8B ?? ?? 8B
alloc(newmem,$1000)

alloc(INJECT_ITEM_REMOVE_NO_DECo, $10)

label(code)
label(return)
