  cmp dword ptr [is_keep_1_goldbar], 1 // gold bar
  jne short next_a
  // gold bar
  cmp qword ptr [rdi+rax+8], Gold_Bar  // 金條
  je short set_gold_bar_x
  cmp qword ptr [rdi+rax+8], Crude_Gold_Bar  //粗糙的金條
