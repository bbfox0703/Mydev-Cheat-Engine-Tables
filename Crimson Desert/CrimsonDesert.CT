  // gold bar
  cmp qword ptr [rdi+rax+8], Aeserions_Scale
  jne short @F
  cmp qword ptr [rdi+rax+10], 1
  ja short @F
  xor r15, r15
@@:

  pop r13

  push r13
  mov r13, [i_min_dec_threshold]
  cmp qword ptr [rdi+rax+10], r13
  jb next_chk
  mov r13, [i_max_dec_threshold]
  cmp qword ptr [rdi+rax+10], r13
  ja short next_chk
  xor r15, r15
