INJECT_ITEM_REMOVE_NO_DECo:
  readmem(INJECT_ITEM_REMOVE_NO_DEC, $10)

newmem:
  push r13
  // min amount gating for specific items

  cmp qword ptr [rdi+rax+8], Copper  // Copper
  jne short @F
  cmp qword ptr [rdi+rax+10], #98000
  jae short @F
  mov qword ptr [rdi+rax+10], #98000
@@: // Camp resources
  {
  cmp qword ptr [rdi+rax+8], #1780  // 營地資金
  jb short @F
  cmp qword ptr [rdi+rax+8], #1784 // 營地兵器
  ja short @F
