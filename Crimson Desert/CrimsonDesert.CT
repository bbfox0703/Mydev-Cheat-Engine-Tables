// ============================================================
//  例外表 (Exception Table)
//  dq &lt;item_id&gt;, &lt;amount&gt;    (每筆 0x10 bytes)
//  按 ID 升序排列
// ============================================================
align 10 cc
exception_table:
// -- ammos --
dq #2, #2 // 持續補給箭
dq #17, #2 // 持續補給 cannon
dq #23, #100 // 子彈
dq #24, #2 // 持續補給子彈
