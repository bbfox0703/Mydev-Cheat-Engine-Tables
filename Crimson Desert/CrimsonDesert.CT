//label(rng_done)
//label(exception_table)
label(range_table is_set_min_mat)
label(i_abyss_cell_amt i_abyss_artifact_amt i_fabyss_artifact_amt i_atag_amt i_mac_resource_amt)
// ============================================================
//  查找優先順序:
//    1. 銀幣         → flag 控制，獨立判定
//    2. 例外表       → 最高優先，覆蓋區間
//    3. 區間表       → ID 落在區間內就套用
//    4. 都沒中       → 不修改，走原始邏輯
//
//  CE 數值: 無前綴 = hex，# 前綴 = 十進位
// ============================================================
//
//  例外表格式: dq &lt;item_id&gt;, &lt;amount&gt;   (每筆 0x10 = 16 bytes)
//  結尾標記:   dq -1, 0
//
//  區間表格式: dq &lt;start&gt;, &lt;end&gt;, &lt;amount&gt;, 0  (每筆 0x20 = 32 bytes)
//  結尾標記:   dq -1, 0, 0, 0
//
//  新增例外 → 插入 dq id, amount (保持 ID 升序)
//  新增區間 → 插入 dq start, end, amount, 0 (保持升序)
// ============================================================
INJECT_INF_ARROW_N_OTHERSo:
  readmem(INJECT_INF_ARROW_N_OTHERS, $F)

newmem:
  //cmp qword ptr [rbx+08], #6100 // item id must &lt;= 6300 (act. 60xx now)
  //ja skip_save_item
  // **** Begin Auto script: AddressCapture
  // mode=List, capacity=1000
  pushfq
  push r15
  push r14
  // Address Capture List
  mov r15, ptrList_arr_INJECT_7868_346234
  xor r14d, r14d
dedup_loop_346234:
  cmp r14d, [ptrList_count_INJECT_7868_346234]
  jge store_new_346234
  cmp [r15+r14*8], rbx
  je skip_store_346234
  inc r14d
  jmp dedup_loop_346234
store_new_346234:
  cmp r14d, #3000
  jge skip_store_346234
  mov [r15+r14*8], rbx
  inc dword ptr [ptrList_count_INJECT_7868_346234]
skip_store_346234:
  pop r14
  pop r15
  popfq
  // **** End Auto script: AddressCapture
skip_save_item:


  // --- 銅幣特殊處理  ---
  cmp dword ptr [rbx+8], Copper
  je check_silver


// ============================================================
//  第一步: 查例外表 (每筆 0x10, index r14 × 10)
// ============================================================
  push r15
  push r14
  push r13

  xor r14, r14
  mov r15, exception_table
exc_loop:
  lea r13, [r15+r14*1]         // r13 = exception_table + r14
  mov r13, [r13]               // r13 = entry item_id
  cmp r13, -1
  je short exc_done
  cmp r13d, [rbx+8]
  jne short exc_next
  // --- 命中例外 ---
  lea r13, [r15+r14*1]
  mov r13, [r13+8]             // r13 = amount
  mov [rbx+10], r13
  jmp short rng_done                 // 直接跳到結束
exc_next:
  add r14, 10                  // 下一筆 (0x10 = 16 bytes)
  jmp short exc_loop

rng_done:
  pop r13
  pop r14
  pop r15
  jmp code

exc_done:

  pop r13
  pop r14
  pop r15
  jmp range_check

// ============================================================
//  共用區間查找子程序
//  輸入:
//    r15 = 表格基址
//    r8b = 模式 (0 = 直接覆寫, 1 = min clamp)
//  讀取:
//    [rbx+8]  = item ID
//    [rbx+10] = 目前數量
//  輸出:
//    [rbx+10] 可能被修改
// ============================================================
range_lookup_sub:
  push r14
  push r13
  xor r14, r14
sub_loop:
  lea r13, [r15+r14*1]
  mov r13, [r13]               // r13 = range_start
  cmp r13, -1
  je sub_done
  cmp [rbx+8], r13d
  jb short sub_next
  lea r13, [r15+r14*1]
  mov r13, [r13+8]             // r13 = range_end
  cmp [rbx+8], r13d
  ja short sub_next
  // --- 命中區間 ---
  lea r13, [r15+r14*1]
  mov r13, [r13+10]            // r13 = amount
  test r8b, r8b
  jnz short sub_clamp
  mov [rbx+10], r13            // 模式 0: 直接覆寫
  jmp short sub_done
sub_clamp:
  cmp [rbx+10], r13            // 模式 1: 只在不足時補到最小值
  jae short sub_done
  mov [rbx+10], r13
  jmp short sub_done
sub_next:
  add r14, 20
  jmp sub_loop
sub_done:
  pop r13
  pop r14
  ret


// ============================================================
//  第二步: 查區間表 (覆寫模式)
// ============================================================
range_check:

  push r15
  push r8

  mov r15, range_table
  xor r8, r8                   // r8b = 0 → 直接覆寫
  call range_lookup_sub

  pop r8
  pop r15

// ============================================================
//  第三步: 查最小值區間表 (clamp 模式)
// ============================================================
check_min_amount:
  cmp dword ptr [is_set_min_mat], 1
  jne code

  push r15
  push r8

  mov r15, min_range_table
  mov r8b, 1                   // r8b = 1 → min clamp
  call range_lookup_sub

  pop r8
  pop r15
  jmp short code

check_silver:
  cmp dword ptr [is_chk_silver], 1
  jne short code
  cmp qword ptr [rbx+10], #98000
  ja short chk_silver_Lamt

  mov qword ptr [rbx+10], #98000
  jmp short code

chk_silver_Lamt:
  cmp qword ptr [rbx+10], #200000
  jbe short code
  mov qword ptr [rbx+10], #200000

code:
  // cmp qword ptr [rbx+10],00
  reassemble(INJECT_INF_ARROW_N_OTHERS)
  // jle CrimsonDesert.exe+1D39984
  reassemble(INJECT_INF_ARROW_N_OTHERS+5)
  // lea rcx,[rbx+08]
  reassemble(INJECT_INF_ARROW_N_OTHERS+7)
  // inc r15w
  reassemble(INJECT_INF_ARROW_N_OTHERS+B)
  jmp far return
  align 10 cc
  ptrList_count_INJECT_7868_346234:
  dd 0 0
  i_item_qty_low:
  dq 1
  i_item_qty_high:
  dq 2
  i_item_id_low:
  dq 1
  i_item_id_high:
  dq #6500

// ============================================================
//  例外表 (Exception Table)
//  dq &lt;item_id&gt;, &lt;amount&gt;    (每筆 0x10 bytes)
//  按 ID 升序排列
// ============================================================
align 10 cc
exception_table:
// -- ammos --
dq #2, #2 // 持續補給箭
dq #16, #100 // 小型砲彈
dq #17, #2 // 持續補給砲彈
dq #23, #100 // 子彈
dq #24, #2 // 持續補給子彈
// --- 鑰匙/雜物 ---
//dq #1199, #50 // 魚肉 Fish fillet
//dq #1208, #50 // Mysterious dish
//dq #1209, #50 // Mysterious liq


// 1.04
//dq #1799, #99999    // Cogwheel
//dq #1800, #99999    // Small Battery
//dq #1801, #99999    // Lubricant
//dq #1802, #99999    // Clockwork Insect

// --- 阿比斯/特殊 ---
// 阿比斯動力核心 Abyss cell
dq Abyss_Cell
i_abyss_cell_amt:
dq #20

// Abyss Artifact 阿比斯神器
dq Abyss_Artifact
i_abyss_artifact_amt:
dq #19

// Faded Abyss Artifact 褪色的阿比斯神器
dq Faded_Abyss_Artifact
i_fabyss_artifact_amt:
dq #18

dq Note_with_a_Suspicious_Symbol, #50    // 帶有可疑紋樣的紙條
dq Shineberry, #10     // Shineberry 閃耀的果實
dq Wild_Ginseng, #50     // 山蔘
dq Refined_Palmar_Pill, #10     // 復甦神丹
dq Palmar_Pill, #10     // 復甦丹藥
// --- 商落未 (母湯苔鯛!) ---
dq -1, 0

// ============================================================
//  區間表 (Range Table)
//  dq &lt;start&gt;, &lt;end&gt;, &lt;amount&gt;, 0   (每筆 0x20 bytes)
//  按起始 ID 升序排列
// ============================================================
align 20 cc

range_table:
dq #0,  #1,  #100, 0    // arrow
dq #3,  #9,  #100, 0    // arrow
dq #18,  #22,  #50, 0    // cannonball
dq #25,  #26,  #100, 0    // bullet
//dq #444,  #515,  #10, 0  // 傢俱
dq Dried_Fish, Sugar_Cubes, #20, 0  // 食物，馬料  Low part: Dried Fish魚乾/1001957, Jerky 風乾肉塊, High part=Sugar Cubes方糖/749101
dq Horse_Tonic,  Astrids_Greater_Elixir,  #10, 0    // 馬用強壯劑/749201 &lt;-&gt; Astrid's Greater Elixir阿斯特麗德的高階藥劑
dq Key,  Master_Key,  #20, 0  // key  Key, &lt;-&gt; Master Key萬能鑰匙
dq Paltry_Copper_Pouch,  Overflowing_Silver_Pouch,  #99, 0 // Paltry Copper Pouch破舊的銅幣小袋子 &lt;-&gt; Overflowing Silver Pouch快要撐破的銀幣袋
dq Hernand_Refinement_Token,  Varnia_Refinement_Token,  #10, 0    // refinement token (coin) 埃爾南德淬火貨幣 &lt;-&gt; 巴爾尼亞淬火貨幣

// Dragon claw龍爪角笛, A.T.A.G.緊急動力裝置, Narima's Horn納里瑪的號角, A.T.A.G. 動力模組
dq Dragon_Claw_Horn,  ATAG_Power_Module
i_atag_amt:
dq #20
dq 0
// ==========================

//Cogwheel齒輪零件, Small Battery小型電池, Lubricant潤滑油, Clockwork Insect機械蟲 (後面又帶三個重覆名稱 齒輪零件 - 潤滑油)
dq Cogwheel,  Clockwork_Insect
i_mac_resource_amt:
dq #99999
dq 0
// =============================
dq Apple_Seed,  Chaya_Seed,  #10, 0    // Seeds    Apple Seed蘋果樹種子 &lt;-&gt; Chaya Seed查亞種子
// dq #xxxx, #yyyy, #zz, 0 // (未來新增區間)
// --- 商落未 (母湯苔鯛!) ---
dq -1, 0, 0, 0


//============================
//
align 10 0
is_chk_silver:
  dd 0, 0
is_set_min_mat:
  dd 1
align 20 0
//
//===================================

// ============================================================
//  設定最小值區間表 (Range Table)
//  dq &lt;start&gt;, &lt;end&gt;, &lt;amount&gt;, 0   (每筆 0x20 bytes)
//  按起始 ID 升序排列
// ============================================================
min_range_table:
dq Ornythion_Swallowtail_Butterfly,  Burrowing_Toad,   #10, 0  // 鳥翼蝶 - 穴居蟾蜍
dq Rosemary,  Cooking_Oil,  #50, 0    // 迷迭香/751103, 薰衣草/751107 &lt;=&gt; 水/22008, 料理用油/752005
dq Ricefish, Shrimp,  #10, 0 //稻田魚 &lt;-&gt; 蝦子
// dq #xxxx, #yyyy, #zz, 0 // (未來新增區間)
// --- 商落未 (母湯苔鯛!) ---
dq -1, 0, 0, 0

INJECT_INF_ARROW_N_OTHERS:
  jmp far newmem
  nop 1
return:
