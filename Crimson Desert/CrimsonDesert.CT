</AssemblerScript>
      <CheatEntries>
        <CheatEntry>
          <ID>121</ID>
          <Description>"Notice: please load game, open item menu first.  Some scripts may not be activated if not do so"</Description>
          <Color>8913FF</Color>
          <GroupHeader>1</GroupHeader>
