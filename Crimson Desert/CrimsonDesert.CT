// ============================================================
//  共用區間查找子程序
//  輸入:
//    r15 = 表格基址
//    r8b = 模式 (0 = 直接覆寫, 1 = min clamp)
//  讀取:
//    [rbx+8]  = item ID
//    [rbx+10] = 目前數量
//  輸出:
//    [rbx+10] 可能被修改
// ============================================================
range_lookup_sub:
  push r14
  push r13
  xor r14, r14
sub_loop:
  lea r13, [r15+r14*1]
  mov r13, [r13]               // r13 = range_start
  cmp r13, -1
  je sub_done
  cmp [rbx+8], r13d
  jb short sub_next
  lea r13, [r15+r14*1]
  mov r13, [r13+8]             // r13 = range_end
  cmp [rbx+8], r13d
  ja short sub_next
  // --- 命中區間 ---
