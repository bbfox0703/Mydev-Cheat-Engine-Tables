//  讀取:
//    [rbx+8]  = item ID
//    [rbx+10] = 目前數量
//  輸出:
//    [rbx+10] 可能被修改
// ============================================================
range_lookup_sub:
  push r14
  push r13
  xor r14, r14
sub_loop:
  lea r13, [r15+r14*1]
  mov r13, [r13]               // r13 = range_start
  cmp r13, -1
