aobscanmodule(INJECT_ITEM_REMOVE_NO_DEC,$process,?? 29 ?? ?? 10 ?? FF FF 00 00 ?? 8B ?? ?? 01 ??)
// raw AOB: 48 8D 4C 24 68 4C 89 64 24 60 66 89 5C 24 68 E8 ?? ?? ?? ?? 41 0F B6 D5 48 89 C1 E8 ?? ?? ?? ?? 49 89 C2 45 31 E4 48 89 F8 48 99 49 F7 FA 48 85 D2 41 0F 95 D4 49 01 C4 48 8B 06 49 29 6C 07 10 B8 FF FF 00 00 48 8B 0E 4C 01 F9 66 3B 41 08 74 ?? 48 83 79 10 00 7E ?? 48 8B 79 10 48 8D 4C 24 68 66 89 5C 24 68 E8 ?? ?? ?? ?? 41 0F B6 D5 48 89 C1 E8 ?? ?? ?? ?? 49 89 C2 41 C7 06 00 00 00 00
// injection point AOB: ?? 29 ?? ?? 10 ?? FF FF 00 00 ?? 8B ?? ?? 01 ?? 66 3B ?? 08 74 ?? ?? 83 ?? 10 00 7E ?? ?? 8B ?? 10 ?? 8D ?? 24 ?? 66 89 ?? 24 ?? E8 ?? ?? ?? ?? ?? 0F B6 ?? ?? 89 ?? E8 ?? ?? ?? ?? ?? 89 ?? ?? C7 ?? 00 00 00 00
alloc(newmem,$1000)

