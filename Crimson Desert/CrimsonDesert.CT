  if not parent then
    print("Cannot find parent node: " .. parentName)
    return
  end
  for i = addressList.Count - 1, 0, -1 do
    local mr = addressList[i]
    if mr.Parent == parent then mr.delete() end
  end
  parent.Active = false
end)

print("Item list nodes cleared.")
closeLuaEngine()



