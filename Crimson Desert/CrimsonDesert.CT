{$lua}
if syntaxcheck then return end
if not getAddressSafe("entityCapturePtr") then
  showMessage("Please enable Move speed multiplier")
  return false
end
{$asm}

alloc(tpData, 256)

label(tpOffsetX)
label(tpOffsetY)
label(tpOffsetZ)
label(tpTrigger)
label(tpMode)
label(tpWpTrigger)
label(tpHeightBoost)

