          <CheatEntries>
            <CheatEntry>
              <ID>186</ID>
              <Description>"2. Move speed multiplier / crow fly mode alt"</Description>
              <Options moHideChildren="1" moDeactivateChildrenAsWell="1"/>
              <VariableType>Auto Assembler Script</VariableType>
              <AssemblerScript>{
  Generated by AOBMaker,  bbfox@https://opencheattables.com
  Date   : 2026/04/25
}

[ENABLE]
{$lua}
if syntaxcheck then return end
if not getAddressSafe("worldOffset_addr") then
  showMessage("Enable SymbolScanner first")
  return false
end
{$asm}
// Step 2. Move speed multiplier / crow fly mode alt
aobscanmodule(INJECT_ENTCAP,$process,C4 ?? ?? 18 ?? ?? 00 00 00 C5 ?? 59 ?? ?? 8B ??)
// raw AOB: 44 89 B7 8C 04 00 00 44 88 B7 88 02 00 00 C5 F0 57 C9 48 8D 8D E0 00 00 00 E8 ?? ?? ?? ?? 85 DB 74 ?? C5 C8 57 F6 C4 C3 49 21 F4 00 C4 C3 49 21 F5 10 C4 C3 49 21 F6 20 66 0F 1F 44 00 00 C5 FA 10 85 E0 00 00 00 C5 FA 58 8F 90 02 00 00 C5 FA 11 8F 90 02 00 00 FF 87 94 02 00 00 C4 E2 79 18 85 E4 00 00 00 C5 F8 59 CE 48 8B 06 C5 F8 11 88 B0 01 00 00 C5 C2 59 8D E4 00 00 00 C5 FA 11 8F 68 03 00 00 48 8D 95 E0 00 00 00 48 8B CF E8 ?? ?? ?? ?? 48 83 EB 01 75 ?? 48 8B 16 C5 F8 10 05 ?? ?? ?? ?? C5 F8 58 B2 90 00 00 00 C5 FA 10 BF 34 02 00 00 48 83 C2 60 48 8D 4C 24 50
// injection point AOB: C4 ?? ?? 18 ?? ?? 00 00 00 C5 ?? 59 ?? ?? 8B ?? C5 ?? 11 ?? B0 01 00 00 C5 ?? 59 ?? ?? 00 00 00 C5 ?? 11 ?? 68 03 00 00 ?? 8D ?? ?? 00 00 00 ?? 8B ?? E8 ?? ?? ?? ?? ?? 83 ?? 01 75 ?? ?? 8B ?? C5 ?? 10 ?? ?? ?? ?? ?? C5 ?? 58 ?? 90 00 00 00 C5 ?? 10 ?? 34 02 00 00 ?? 83 ?? 60 ?? 8D ?? 24
alloc(newmem,$1000)

alloc(INJECT_ENTCAPo, $10)
alloc(entityCapturePtr, 8)

label(code)
label(return)
label(vf_move_speed_multi vf_move_z_mul cur_z_loc vf_vec_down_factor is_enable_move_spd_multi)

entityCapturePtr:
  dq 0

INJECT_ENTCAPo:
  readmem(INJECT_ENTCAP, $10)

newmem:

code:
  // vbroadcastss xmm0,[rbp+000000E4]
  reassemble(INJECT_ENTCAP)
  // vmulps xmm1,xmm0,xmm6
  reassemble(INJECT_ENTCAP+9)

  // move code start
  // -- speed/fly multiplier xmm1 --
  cmp dword ptr [is_enable_move_spd_multi], 1
  jne endp
  // xmm1 = desired velocity {X, Z(height), Y, W}
  // Apply speed multiplier
  vmovss xmm15, [vf_move_speed_multi]
  vshufps xmm15, xmm15, xmm15, 0   // {speed, speed, speed, speed}

  // Check Z velocity (lane 1 = height)
  vshufps xmm12, xmm1, xmm1, 1     // xmm12[0] = Z velocity
  vmovss [cur_z_loc], xmm12
  vxorps xmm13, xmm13, xmm13
  vcomiss xmm12, xmm13
  jae short to_going_up

  // Going down: replace Z lane multiplier with down_factor
  // xmm15 = {speed, speed, speed, speed} -&gt; {speed, down_factor, speed, speed}
  vmovss xmm14, [vf_vec_down_factor]
  vinsertps xmm15, xmm15, xmm14, 10   // dest lane 1 = down_factor
  jmp short to_apply

to_going_up:
  // Going up: apply Z extra multiplier to lane 1
  // xmm15 = {speed, speed, speed, speed} -&gt; {speed, speed*z_mul, speed, speed}
  vmovss xmm14, [vf_move_z_mul]
  vmulss xmm14, xmm14, xmm15            // z_mul * speed
  vinsertps xmm15, xmm15, xmm14, 10   // dest lane 1

to_apply:
  vmulps xmm1, xmm1, xmm15
endp:
  // code end

  // mov rax,[rsi]
  reassemble(INJECT_ENTCAP+D)

  // !!!! capture entity ptr
  push rcx
  mov  rcx, entityCapturePtr
  mov  [rcx], rax
  pop  rcx

  jmp far return
  align 10 cc
  vf_move_speed_multi:
    dd (float)1.3333333
    dd 0 0 0
  vf_move_z_mul:
    dd (float)2.0          // going up: Z *= speed * this
    dd 0 0 0
  vf_vec_down_factor:
    dd (float)0.333333333          // going down: Z *= this (not multiplied by speed)
    dd 0 0 0
  cur_z_loc:
    dd 0
  is_enable_move_spd_multi:
  dd 1

INJECT_ENTCAP:
  jmp far newmem
  nop 2
return:
registersymbol(INJECT_ENTCAP INJECT_ENTCAPo)
registersymbol(entityCapturePtr)
registersymbol(vf_move_speed_multi vf_move_z_mul cur_z_loc vf_vec_down_factor is_enable_move_spd_multi)
[DISABLE]

INJECT_ENTCAP:
  readmem(INJECT_ENTCAPo, $10)

unregistersymbol(INJECT_ENTCAP INJECT_ENTCAPo)
dealloc(newmem)
dealloc(INJECT_ENTCAPo)
dealloc(entityCapturePtr)
unregistersymbol(entityCapturePtr)
unregistersymbol(vf_move_speed_multi vf_move_z_mul cur_z_loc vf_vec_down_factor is_enable_move_spd_multi)

