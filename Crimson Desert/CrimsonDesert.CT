  cmp qword ptr [rdi+rax+8], Cogwheel
  jb short @F
  cmp qword ptr [rdi+rax+8], Clockwork_Insect
  ja short @F
  cmp qword ptr [rdi+rax+10], #9999
  jae short @F
  mov qword ptr [rdi+rax+10], #9999
