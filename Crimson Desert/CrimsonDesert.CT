  jae short endp

  mov r13, [i_force_dec_threshold]
  cmp qword ptr [rdx+rax+10], r13
  ja short endp
  mov r13, [i_max_dec_threshold]
  cmp qword ptr [rdx+rax+10], r13
  jb short endp
