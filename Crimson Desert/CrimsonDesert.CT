dq 0
// =============================
//dq #2804,  #2823,  #10, 0    // Seeds    2804=Apple Seed, 2823=Chaya Seed
// dq #xxxx, #yyyy, #zz, 0 // (未來新增區間)
// --- 商落未 (母湯苔鯛!) ---
dq -1, 0, 0, 0

