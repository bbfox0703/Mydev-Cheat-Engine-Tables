aobscanmodule(INJECT_ITEM_REMOVE_NO_DEC,$process,?? 29 ?? 07 10 ?? 8B ?? ?? 01 ?? 66 ?? 3B ?? 08)
// raw AOB: E9 ?? ?? ?? ?? 48 8D 4C 24 68 66 89 5C 24 68 E8 ?? ?? ?? ?? 41 0F B6 D4 48 89 C1 E8 ?? ?? ?? ?? 49 89 C2 48 89 E8 48 99 31 ED 49 F7 FA 48 85 D2 40 0F 95 D5 48 01 C5 48 8B 06 4C 29 7C 07 10 48 8B 0E 48 01 F9 66 44 3B 69 08 74 ?? 48 83 79 10 00 7E ?? 48 8B 79 10 48 8D 4C 24 68 66 89 5C 24 68 E8 ?? ?? ?? ?? 41 0F B6 D4 48 89 C1 E8 ?? ?? ?? ?? 49 89 C2 41 C7 06 00 00 00 00 48 89 F8
// injection point AOB: ?? 29 ?? 07 10 ?? 8B ?? ?? 01 ?? 66 ?? 3B ?? 08 74 ?? ?? 83 ?? 10 00 7E ?? ?? 8B ?? 10 ?? 8D ?? 24 ?? 66 89 ?? 24 ?? E8 ?? ?? ?? ?? ?? 0F B6 ?? ?? 89 ?? E8 ?? ?? ?? ?? ?? 89 ?? ?? C7 ?? 00 00 00 00 ?? 89
