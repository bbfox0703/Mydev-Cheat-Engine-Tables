  mov [rbx+10], r13            // 模式 0: 直接覆寫
  jmp short sub_done
sub_clamp:
  cmp [rbx+10], r13            // 模式 1: 只在不足時補到最小值
  jae short sub_done
  mov [rbx+10], r13
  jmp short sub_done
sub_next:
  add r14, 20
  jmp sub_loop
sub_done:
