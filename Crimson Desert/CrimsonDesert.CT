//  dq &lt;start&gt;, &lt;end&gt;, &lt;amount&gt;, 0   (每筆 0x20 bytes)
//  按起始 ID 升序排列
// ============================================================
min_range_table:
dq #993,  #1138,  #50, 0    // 1007 = Rosemary, 1008 = Lavender, 1151 = Water, 1152 = Cooking Oil
// dq #xxxx, #yyyy, #zz, 0 // (未來新增區間)
// --- 商落未 (母湯苔鯛!) ---
dq -1, 0, 0, 0

