  mov r15, [i_fek_max_hp_threshold2]
  cmp dword ptr [rdi+18], r15
  pop r15
  jae short @F

  cmp dword ptr [rdi+A0], 64
  je short chk_next
  cmp qword ptr [rdi+10], 64 // Spirit delta
  je short chk_next
  cmp qword ptr [rdi+10], #4000  // Sta delta
