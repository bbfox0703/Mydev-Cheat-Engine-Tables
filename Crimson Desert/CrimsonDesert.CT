+mov [rbp+00000460], al    ← 第 2 個 gate 替代路徑

接著進入逐敵迴圈 (+821840 ~ +821A0C)，每個敵人做： (address 已經不對)
  +821946: call +6A1D50            ← parry 判定函式（回傳 AL）
  +82194B: movzx ebx, al           ← bl = "本敵能 parry 嗎"
  +82195F: test bl, bl
  +821961: je +82197F              ← bl=0 跳過
  +821963: cmp byte [rbp+450], 0   ← Treseed 的 G1 AOB
  +82196A: je +82197F              ← G1=0 跳過
  +82196E: jne +82197F             ← esi 已記錄則跳過
  +821970: mov esi, [r14+60]       ← 成功！記錄 parry 目標

  ... 第二類 parry（反擊？）...
  +8219D5: test bl, bl
  +8219D7: je +8219FE
  +8219D9: cmp byte [rbp+460], 0   ← Treseed 的 G2 AOB
  +8219E0: je +8219FE

最後 +821A3C: mov [r13+0000022B], al  ← 寫回玩家結構的 parry 結果

位址	原 byte	角色
+821961	74 1C	bl=0 跳過第 1 類 parry
+82196A	74 13	G1=0 跳過第 1 類 parry（Parry G1）
+8219D7	74 25	bl=0 跳過第 2 類 parry
+8219E0	74 1C	G2=0 跳過第 2 類 parry（Parry G2）
}
 
