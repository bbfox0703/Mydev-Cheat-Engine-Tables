aobscanmodule(INJECT_SET_ATTACK_DEFENSE,$process,?? 8B ?? 18 ?? C1 ?? 05 ?? 8B ?? 01 ?? 89 ??)
alloc(newmem,$1000)
alloc(INJECT_SET_ATTACK_DEFENSEo, $F)

label(code)
label(return)
label(check_defense)
label(do_store)
label(attack_enabled attack_value)
label(defense_enabled defense_value)

INJECT_SET_ATTACK_DEFENSEo:
  readmem(INJECT_SET_ATTACK_DEFENSE, $F)

newmem:

code:
  // ====== 原始 3 條 load，跑完後 RCX = 原 attribute 值 ======
  // mov rax,[r14+18]
  reassemble(INJECT_SET_ATTACK_DEFENSE)
  // shl rcx,05
  reassemble(INJECT_SET_ATTACK_DEFENSE+4)
  // mov rcx,[rcx+rax]
  reassemble(INJECT_SET_ATTACK_DEFENSE+8)

  // ====== Slot override (BL = attribute type id) ======
  cmp bl, 03                          // Attack
  jne short check_defense
  cmp dword ptr [attack_enabled], 1
  jne short do_store
  mov rcx, [attack_value]
  jmp short do_store

check_defense:
  cmp bl, 04                          // Defense
  jne short do_store
  cmp dword ptr [defense_enabled], 1
  jne short do_store
  mov rcx, [defense_value]

do_store:
  // mov [rsi],rcx                    // 原 store，RCX 可能已被換掉
  reassemble(INJECT_SET_ATTACK_DEFENSE+C)
  jmp far return

  align 10 cc
attack_enabled:
  dd 0
  dd 0
attack_value:
  dq #121000                          // 121 × 1000
defense_enabled:
  dd 1
  dd 0
defense_value:
  dq #451000

INJECT_SET_ATTACK_DEFENSE:
  jmp far newmem
  nop 1
return:
registersymbol(INJECT_SET_ATTACK_DEFENSE INJECT_SET_ATTACK_DEFENSEo)
registersymbol(attack_enabled attack_value)
registersymbol(defense_enabled defense_value)

[DISABLE]

INJECT_SET_ATTACK_DEFENSE:
  readmem(INJECT_SET_ATTACK_DEFENSEo, $F)

unregistersymbol(INJECT_SET_ATTACK_DEFENSE INJECT_SET_ATTACK_DEFENSEo)
unregistersymbol(attack_enabled attack_value)
unregistersymbol(defense_enabled defense_value)
dealloc(newmem)
dealloc(INJECT_SET_ATTACK_DEFENSEo)

