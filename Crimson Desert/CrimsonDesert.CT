dq #3019, #50     // 山蔘
dq #3022, #10     // 復甦神丹
dq #3023, #10     // 復甦丹藥
// --- 商落未 (母湯苔鯛!) ---
dq -1, 0
// ============================================================
//  區間表 (Range Table)
//  dq &lt;start&gt;, &lt;end&gt;, &lt;amount&gt;, 0   (每筆 0x20 bytes)
//  按起始 ID 升序排列
// ============================================================
align 20 cc

range_table:
dq #0,  #1,  #100, 0    // arrow
dq #3,  #9,  #100, 0    // arrow
dq #18,  #22,  #50, 0    // cannonball
dq #25,  #26,  #100, 0    // bullet
//dq #444,  #515,  #10, 0  // 傢俱
dq #1196, #1495, #20, 0  // 食物，馬料  Low part: Dried Fish魚乾, 1197=Jerky 風乾肉塊, High part=Sugar Beet甜菜, Sugar Cubes方糖
dq #1498,  #1512,  #10, 0    // Potions Freya's Lesser Elixir芙蕾雅的初階藥劑 &lt;-&gt; Astrid's Greater Elixir阿斯特麗德的高階藥劑
dq #1740,  #1743,  #20, 0  // key  Key, &lt;-&gt; Master Key萬能鑰匙
dq #1771,  #1777,  #99, 0 // Paltry Copper Pouch破舊的銅幣小袋子 &lt;-&gt; Overflowing Silver Pouch快要撐破的銀幣袋
dq #1799,  #1805,  #10, 0    // refinement token (coin) 埃爾南德淬火貨幣 &lt;-&gt; 巴爾尼亞淬火貨幣

// Dragon claw龍爪角笛, A.T.A.G.緊急動力裝置, Narima's Horn納里瑪的號角, A.T.A.G. 動力模組
dq #1584,  #1587
i_atag_amt:
dq #20
dq 0
// ==========================

//Cogwheel齒輪零件, Small Battery小型電池, Lubricant潤滑油, Clockwork Insect機械蟲 (後面又帶三個重覆名稱 齒輪零件 - 潤滑油)
dq #1785,  #1788
i_mac_resource_amt:
dq #99999
dq 0
// =============================
dq #2997,  #3016,  #10, 0    // Seeds    Apple Seed蘋果樹種子 &lt;-&gt; Chaya Seed查亞種子
// dq #xxxx, #yyyy, #zz, 0 // (未來新增區間)
// --- 商落未 (母湯苔鯛!) ---
dq -1, 0, 0, 0

//============================
//
align 10 0
is_chk_silver:
  dd 0, 0
is_set_min_mat:
  dd 1
align 20 0
//
//===================================

// ============================================================
//  設定最小值區間表 (Range Table)
//  dq &lt;start&gt;, &lt;end&gt;, &lt;amount&gt;, 0   (每筆 0x20 bytes)
