                  <ID>191</ID>
                  <Description>"3. Map waypoint position capture"</Description>
                  <Options moHideChildren="1" moDeactivateChildrenAsWell="1"/>
                  <VariableType>Auto Assembler Script</VariableType>
                  <AssemblerScript>{
  Generated by AOBMaker,  bbfox@https://opencheattables.com
  Date   : 2026/05/24
}

[ENABLE]
// step 3. Map waypoint position capture (read-hook, pointer mode)
// Hooks +B2C869 which only fires for the on-map marker.
// Saves rcx (marker struct base). Lua reads coords live from [rcx+D8..E0].

// Exact bytes from disasm: vsubss xmm6,xmm10,[rcx+D8]; vsubss xmm7,xmm9,[rcx+E0]; add rcx, ...
aobscanmodule(INJECT_WPCAP,$process,C5 ?? 5C ?? E0 00 00 00 C5 ?? 5C ?? E8 00 00 00)
// raw AOB: 75 ?? 49 8B F0 49 8B D8 BF FF FF FF FF 44 8B FF 44 8B F7 EB ?? 48 8B 46 18 48 8B 18 41 8B F8 44 8B 7E 0C 48 85 DB 0F 84 ?? ?? ?? ?? 44 39 7E 0C 0F 85 ?? ?? ?? ?? 48 8B 4B 18 C5 AA 5C B1 E0 00 00 00 C5 B2 5C B9 E8 00 00 00 48 81 C1 DE 00 00 00 E8 ?? ?? ?? ?? C5 FA 10 98 88 00 00 00 C5 CA 59 C6 C4 C1 7A 58 CB C5 C2 59 C7 C5 F2 58 D0 C5 E2 59 CB C5 F8 2F CA 76 ?? 48 8B 4B 18 C5 FA 10 81 E4 00 00 00 32 C0 C4 C1 78 2E C3 7A
// injection point AOB: C5 ?? 5C ?? E0 00 00 00 C5 ?? 5C ?? E8 00 00 00 ?? 81 ?? DE 00 00 00 E8 ?? ?? ?? ?? C5 ?? 10 ?? 88 00 00 00 C5 ?? 59 ?? C4 ?? ?? 58 ?? C5 ?? 59 ?? C5 ?? 58 ?? C5 ?? 59 ?? C5 ?? 2F ?? 76 ?? ?? 8B ?? 18 C5 ?? 10 ?? E4 00 00 00 32 ?? C4 ?? ?? 2E ?? 7A
alloc(newmem,$1000)

alloc(INJECT_WPCAPo, $10)


label(code)
label(return)
label(wpCapturedPtr)
label(wpHitCounter)

INJECT_WPCAPo:
  readmem(INJECT_WPCAP, $10)

newmem:
code:
  // ---- Run the two originals first (literal bytes -- avoid reassemble quirks for VEX) ----
  // vsubss xmm6,xmm10,[rcx+000000E0]
  reassemble(INJECT_WPCAP)
  // vsubss xmm7,xmm9,[rcx+000000E8]
  reassemble(INJECT_WPCAP+8)

  // ---- Save marker struct pointer (rcx). No reg clobber, no flag change. ----
  mov  [wpCapturedPtr], rcx

  // ---- Diagnostic counter (inc modifies flags, wrap in pushfq/popfq) ----
  pushfq
  inc qword ptr [wpHitCounter]
  popfq

  jmp far return
  align 10 cc
  wpCapturedPtr:
  dq 0
  wpHitCounter:
  dq 0

INJECT_WPCAP:
  jmp far newmem
  nop 2
return:

registersymbol(INJECT_WPCAP)
registersymbol(INJECT_WPCAPo)
registersymbol(wpCapturedPtr)
registersymbol(wpHitCounter)

[DISABLE]
INJECT_WPCAP:
  readmem(INJECT_WPCAPo, $10)

unregistersymbol(INJECT_WPCAP)
unregistersymbol(INJECT_WPCAPo)
unregistersymbol(wpCapturedPtr)
unregistersymbol(wpHitCounter)
dealloc(newmem)
dealloc(INJECT_WPCAPo)
