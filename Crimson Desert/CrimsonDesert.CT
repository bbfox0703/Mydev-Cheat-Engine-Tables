  cmp qword ptr [r15+rax+8], Cogwheel
  jb short @F
  cmp qword ptr [r15+rax+8], Clockwork_Insect
  ja short @F
  cmp qword ptr [r15+rax+10], #9999
  jae short @F
  mov qword ptr [r15+rax+10], #9999
