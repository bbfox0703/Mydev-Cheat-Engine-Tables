  </Files>
  <CheatEntries>
    <CheatEntry>
      <ID>0</ID>
      <Description>"Toggle Scripts"</Description>
      <Color>3174FF</Color>
      <VariableType>Auto Assembler Script</VariableType>
      <AssemblerScript Async="1">[ENABLE]
{$lua}
if (syntaxcheck) then return end
synchronize(function()
  getLuaEngine().menuItem5.doClick()
  getLuaEngine().Close()
end)

-- attach process
local processName = "CrimsonDesert.exe"
local pid = getProcessIDFromProcessName(processName)
if pid ~= nil and pid &gt; 0 then
  local currentPid = getOpenedProcessID() or 0
  if currentPid ~= pid then
    openProcess(processName)
    print("Attached to: " .. processName)
    Sleep(333)
  else
    print("Already attached to: " .. processName)
  end
end
synchronize(function()
  getLuaEngine().Close()
end)

local enableBattleScripts = {
  2, -- "Toggle Compact View"
  3, -- "Fast friendship"
  4, -- "Fast pet friendship and take"
  29, -- "When item decrease: no change in defined range"
  39, -- "Menu: when add item amount: set item amount"
  59, -- "Get HP address: Step 1 &amp; 2 - AOB mode"
  147, -- "Abyss Gear"
  155, -- "inf. weapon polishing durability"
  184, -- "Blink spell"
  350, -- "Auto fill HP/Sta/Spi, if data available"
  360, -- "Set attack/defense"
  370, -- "Fast dragon cooldown"
  371, -- "ez Parry"
  374, -- "Get current char pointer"
  66, -- "+Step 2 Usage: open item menu"
  148, -- ""Greater" gear: durability no decrease"
  185, -- "1. Get worldOffset"
  366, -- "ez Parry - Path 1 / Gate 1"
  367, -- "ez Parry - Path 2 / Gate 2"
  375, -- "Char"
  186, -- "2. Move speed multiplier / crow fly mode alt"
  191, -- "3. Map waypoint position capture"
  195, -- "4. Generate scripts"
  372, -- "no clip speed"
  58, -- "reputation no decrease"

}
local addressList = getAddressList()
synchronize(function()
  for _, id in ipairs(enableBattleScripts) do
    local memRec = addressList.getMemoryRecordByID(id)
    if memRec and not memRec.Active then
      memRec.Active = true
      sleep(30)
    end
    addressList.refresh()
  end
end)
synchronize(function() getLuaEngine().Close() end)
[DISABLE]
{$lua}
if (syntaxcheck) then return end
synchronize(function()
  getLuaEngine().menuItem5.doClick()
  getLuaEngine().Close()
end)

local disableBattleScripts = {
  372, -- "no clip speed"
  195, -- "4. Generate scripts"
  406, -- "Others"
  404, -- "Sta #2_H"
  324, -- "Spi #1_C"
  323, -- "Disp Spi #1"
  191, -- "3. Map waypoint position capture"
  153, -- "Duplicate abyss gear when extracted - Step 2"
  151, -- "Duplicate abyss gear when extracted - Step 2"
  136, -- "Get Horse HP - another ptr map mode"
  127, -- "Auto fill Spi (only when Spi1/2 pointer map enabled)"
  124, -- "Auto fill Sta (only when Sta1/2 pointer map enabled)"
  121, -- "Auto fill HP (only when HP1/2 pointer map enabled)"
  116, -- "Auto fill Spi (only when Spi1/2 pointer map enabled)"
  113, -- "Auto fill Sta (only when Sta1/2 pointer map enabled)"
  110, -- "Auto fill HP (only when HP1/2 pointer map enabled)"
  105, -- "Auto fill Spi (only when Spi1/2 pointer map enabled)"
  102, -- "Auto fill Sta (only when Sta1/2 pointer map enabled)"
  99, -- "Auto fill HP (only when HP1/2 pointer map enabled)"
  70, -- "Sta #1_C"
  69, -- "HP #1_C"
  63, -- "Disp Sta #1"
  62, -- "Disp HP #1"
