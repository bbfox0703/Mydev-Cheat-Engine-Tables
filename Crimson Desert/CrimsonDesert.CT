    print(string.format('[SymbolScanner] %s registered at: %X', entry.name, final_addr))
    synchronize(function()
      getLuaEngine().Close()
    end)
  else
    print(string.format('[SymbolScanner] WARNING: AOB scan failed for %s', entry.name))
