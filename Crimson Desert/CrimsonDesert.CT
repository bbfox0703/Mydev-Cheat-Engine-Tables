    <CheatEntry>
      <ID>357</ID>
      <Description>"open item ID query GUI"</Description>
      <VariableType>Auto Assembler Script</VariableType>
      <AssemblerScript Async="1">{$lua}
-- ============================================================
-- Item ID Finder GUI
-- 從 ItemID. / ItemID-zh_tw. / ItemID-ja. 三個 dropdown options
-- 提供 partial match、不分大小寫、跨語系搜尋
-- ============================================================
{$asm}

[ENABLE]
{$lua}
if syntaxcheck then return end

-- 避免重複開啟
if itemFinderForm ~= nil and not itemFinderForm.Destroyed then
  itemFinderForm.show()
  itemFinderForm.BringToFront()
  return
end

------------------------------------------------------------
-- 1. 讀取三個 MemoryRecord 的 dropdown options
--    AddressList / MemoryRecord 屬於 GUI thread,需要 synchronize
------------------------------------------------------------
local linesEN, linesTW, linesJA

synchronize(function()
  local function loadDropdownLines(recName)
    local mr = AddressList.getMemoryRecordByDescription(recName)
    if mr == nil then
      error('MemoryRecord not found: ' .. recName)
    end
    local list = mr.DropDownList
    local lines = {}
    if list ~= nil then
      for i = 0, list.Count - 1 do
        lines[#lines + 1] = list[i]
      end
    end
    return lines
  end

  linesEN = loadDropdownLines('ItemID.')
  linesTW = loadDropdownLines('ItemID-zh_tw.')
  linesJA = loadDropdownLines('ItemID-ja.')
end)

------------------------------------------------------------
-- 2. 純 Lua 解析,不碰 GUI,留在 worker thread
------------------------------------------------------------
local function splitIdDesc(line)
  local colonPos = string.find(line, ':', 1, true)
  if colonPos == nil then return line, '' end
  return string.sub(line, 1, colonPos - 1),
         string.sub(line, colonPos + 1)
end

local function buildLookup(lines)
  local map = {}
  for i = 1, #lines do
    local id, desc = splitIdDesc(lines[i])
    map[id] = desc
  end
  return map
end

local lookupTW = buildLookup(linesTW)
local lookupJA = buildLookup(linesJA)

local items = {}
local total = #linesEN

for i = 1, total do
  local id, descEN = splitIdDesc(linesEN[i])
  local descTW = lookupTW[id] or ''
  local descJA = lookupJA[id] or ''

  local parts = { id, descEN }
  if descTW ~= '' then parts[#parts + 1] = descTW end
  if descJA ~= '' then parts[#parts + 1] = descJA end
  local key = string.lower(table.concat(parts, ' '))

  items[i] = {
    id = id, en = descEN, tw = descTW, ja = descJA,
    searchKey = key,
  }
end

------------------------------------------------------------
-- 3. 顯示語系
------------------------------------------------------------
local currentLang = 'tw'

local function descOf(item, lang)
  local d
  if lang == 'en' then d = item.en
  elseif lang == 'ja' then d = item.ja
  else d = item.tw end
  if d == '' then return '(' .. item.en .. ')' end
  return d
end

------------------------------------------------------------
-- 4~7. 建立 GUI / 綁事件 / 顯示
-- AA script 在 worker thread 跑,GUI 必須 synchronize 到 main thread
------------------------------------------------------------
synchronize(function()
  itemFinderForm = createForm(false)
  itemFinderForm.Caption = 'Item ID Finder (' .. total .. ' items)'
  itemFinderForm.Width = 720
  itemFinderForm.Height = 540
  itemFinderForm.Position = 'poScreenCenter'

  -- 上方 Filter panel (只放 filter + radio group)
  local pnlTop = createPanel(itemFinderForm)
  pnlTop.Align = 'alTop'
  pnlTop.Height = 60          -- 不再放 lblCount,可縮回 60
  pnlTop.BevelOuter = 'bvNone'

  local lblFilter = createLabel(pnlTop)
  lblFilter.Caption = 'Filter:'
  lblFilter.Left = 10
  lblFilter.Top = 18

  local edtFilter = createEdit(pnlTop)
  edtFilter.Left = 70
  edtFilter.Top = 14
  edtFilter.Width = 400

  local rgLang = createRadioGroup(pnlTop)
  rgLang.Left = 480
  rgLang.Top = 0
  rgLang.Width = 220
  rgLang.Height = 56
  rgLang.Caption = 'Display Lang'
  rgLang.Columns = 3
  rgLang.Items.add('EN')
  rgLang.Items.add('TW')
  rgLang.Items.add('JA')
  rgLang.ItemIndex = (currentLang == 'en' and 0) or
                     (currentLang == 'tw' and 1) or 2

  -- 中間 Status panel (獨立一條,放 lblCount)
  local pnlStatus = createPanel(itemFinderForm)
  pnlStatus.Align = 'alTop'   -- 也是 alTop,會疊在 pnlTop 下方
  pnlStatus.Height = 26
  pnlStatus.BevelOuter = 'bvNone'

  local lblCount = createLabel(pnlStatus)
  lblCount.Align = 'alClient'  -- 整個 panel 都給 label,自動填滿
  lblCount.Caption = 'Type to filter (case-insensitive, all languages)'

  -- 下方 ListView
  local lv = createListView(itemFinderForm)
  lv.Align = 'alClient'
  lv.ViewStyle = 'vsReport'
  lv.RowSelect = true
  lv.ReadOnly = true
  lv.MultiSelect = true
  lv.Columns.add().Caption = 'ID'
  lv.Columns[0].Width = 100
  lv.Columns.add().Caption = 'Description'
  lv.Columns[1].Width = 600

  -- 底部按鈕區
  local pnlBottom = createPanel(itemFinderForm)
  pnlBottom.Align = 'alBottom'
  pnlBottom.Height = 52
  pnlBottom.BevelOuter = 'bvNone'

  local btnCopy = createButton(pnlBottom)
  btnCopy.Caption = 'Copy ID(s)'
  btnCopy.Left = 10
  btnCopy.Top = 8
  btnCopy.Height = 32
  btnCopy.Width = 110

  local btnClose = createButton(pnlBottom)
  btnClose.Caption = 'Close'
  btnClose.Left = 600
  btnClose.Top = 8
  btnClose.Height = 32
  btnClose.Width = 90

  --------------------------------------------------------
  -- Filter 邏輯 (closure 內,可存取 lv / edtFilter / rgLang / lblCount)
  --------------------------------------------------------
  local function rebuildList()
    local q = string.lower(edtFilter.Text)
    local lang = (rgLang.ItemIndex == 0 and 'en')
              or (rgLang.ItemIndex == 1 and 'tw')
              or 'ja'

    lv.Items.beginUpdate()
    lv.Items.clear()

    local matched = 0
    local cap = 2000  -- 安全上限,避免空字串時建 6200 個 item 太慢
    local empty = (q == '')

    for i = 1, total do
      local it = items[i]
      if empty or string.find(it.searchKey, q, 1, true) then
        matched = matched + 1
        if matched &lt;= cap then
          local row = lv.Items.add()
          row.Caption = it.id
          row.SubItems.add(descOf(it, lang))
        end
      end
    end

    lv.Items.endUpdate()

    if matched &gt; cap then
      lblCount.Caption = string.format(
        'Matched %d (showing first %d) - type more to narrow',
        matched, cap)
    else
      lblCount.Caption = string.format('Matched %d / %d', matched, total)
    end
  end

  --------------------------------------------------------
  -- Copy 邏輯
  --------------------------------------------------------
  local function copySelectedIds()
    if lv.SelCount == 0 then
      showMessage('No item selected.')
      return
    end
    local ids = {}
    -- 走訪所有 items,挑出 .Selected = true 的
    local count = lv.Items.Count
    for i = 0, count - 1 do
      local it = lv.Items[i]
      if it.Selected then
        ids[#ids + 1] = it.Caption
      end
    end
    writeToClipboard(table.concat(ids, '\r\n'))
    lblCount.Caption = string.format('Copied %d ID(s) to clipboard', #ids)
  end

  --------------------------------------------------------
  -- 事件綁定
  --------------------------------------------------------
  edtFilter.OnChange = rebuildList
  rgLang.OnClick    = rebuildList
  btnCopy.OnClick   = copySelectedIds
  btnClose.OnClick  = function() itemFinderForm.close() end

  -- 雙擊複製單一 ID
  lv.OnDblClick = function()
    if lv.Selected ~= nil then
      writeToClipboard(lv.Selected.Caption)
      lblCount.Caption = 'Copied: ' .. lv.Selected.Caption
    end
  end

  -- Ctrl+C 複製
  lv.OnKeyDown = function(sender, key, shift)
    -- key 67 = 'C',shift 是 table,可能含 'ssCtrl'
    if key == 67 then
      for _, v in ipairs(shift) do
        if v == 'ssCtrl' then
          copySelectedIds()
          return
        end
      end
    end
  end

  -- 表單關閉時清掉全域變數
  itemFinderForm.OnClose = function(sender)
    itemFinderForm = nil
    return caFree
  end

  -- 初始顯示
  rebuildList()
  itemFinderForm.show()
  itemFinderForm.ActiveControl = edtFilter   -- 取代 SetFocus
end)


[DISABLE]
{$lua}
if syntaxcheck then return end
synchronize(function()
  if itemFinderForm ~= nil and not itemFinderForm.Destroyed then
    itemFinderForm.close()
  end
  itemFinderForm = nil
end)

