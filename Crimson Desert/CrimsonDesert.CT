  jne short @F
  // gold bar
  cmp qword ptr [rdx+rax+8], Aeserions_Scale
  jne short @F
  cmp qword ptr [rdx+rax+10], 1
  ja short @F
  xor rcx, rcx
@@:

  pop r13

  push r13
  mov r13, [i_min_dec_threshold]
  cmp qword ptr [rdx+rax+10], r13
  jb next_chk
  mov r13, [i_max_dec_threshold]
  cmp qword ptr [rdx+rax+10], r13
  ja short next_chk
  xor rcx, rcx
  mov [rsp+000001C8], rcx
  jmp endp

next_chk:
  cmp qword ptr [is_special_dec_limit], 1
  jne endp

