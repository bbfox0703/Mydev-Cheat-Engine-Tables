    <CheatEntry>
      <ID>18</ID>
      <Description>"Get char HP"</Description>
      <Options moHideChildren="1" moDeactivateChildrenAsWell="1"/>
      <GroupHeader>1</GroupHeader>
      <CheatEntries>
        <CheatEntry>
          <ID>19</ID>
          <Description>"Usage: enable in menu"</Description>
          <Color>8000FF</Color>
          <GroupHeader>1</GroupHeader>
        </CheatEntry>
        <CheatEntry>
          <ID>20</ID>
          <Description>"Re-enable when zoning"</Description>
          <Color>8000FF</Color>
          <GroupHeader>1</GroupHeader>
        </CheatEntry>
        <CheatEntry>
          <ID>604</ID>
          <Description>"Enable Auto HP valid monitor"</Description>
          <VariableType>Auto Assembler Script</VariableType>
          <AssemblerScript>[ENABLE]
{$lua}
if syntaxcheck then return end

local INTERVAL_MS = 500
local TOGGLE_DELAY_MS = 200

local function doCheck()
  local al = getAddressList()
  local mrHP = al.getMemoryRecordByDescription("HP:")
  local mrMinHP = al.getMemoryRecordByDescription("Min. HP")
  local mrClamp = al.getMemoryRecordByDescription("Enable HP clamp")

  if mrHP == nil or mrMinHP == nil or mrClamp == nil then return end

  -- 讀 HP
  local ok1, hp = pcall(function()
    local addr = mrHP.CurrentAddress
    if addr == nil or addr == "??" then return nil end
    return readInteger(addr)
  end)
  if not ok1 or hp == nil then return end

  -- 讀 Min. HP
  local ok2, minHP = pcall(function()
    local addr = mrMinHP.CurrentAddress
    if addr == nil or addr == "??" then return nil end
    return readInteger(addr)
  end)
  if not ok2 or minHP == nil then return end

  -- 條件：HP &lt; Min. HP 或 HP &gt; 2000
  if hp &lt; minHP or hp &gt; 2000 then
    mrClamp.Active = false

    local reactivateTimer = createTimer(nil, false)
    reactivateTimer.Interval = TOGGLE_DELAY_MS
    reactivateTimer.OnTimer = function(t)
      t.Enabled = false
      t.destroy()
      local mr2 = al.getMemoryRecordByDescription("Enable HP clamp")
      if mr2 ~= nil then
        mr2.Active = true
      end
    end
    reactivateTimer.Enabled = true
  end
end

-- 清除舊的（防重複啟用）
if hpMonitorTimer then
  hpMonitorTimer.Enabled = false
  hpMonitorTimer.destroy()
end

hpMonitorTimer = createTimer(nil, false)
hpMonitorTimer.Interval = INTERVAL_MS
hpMonitorTimer.OnTimer = function(t)
  doCheck()
end
hpMonitorTimer.Enabled = true

--print("[HP Monitor] 已啟動")
{$asm}

[DISABLE]
{$lua}
if syntaxcheck then return end

if hpMonitorTimer then
  hpMonitorTimer.Enabled = false
  hpMonitorTimer.destroy()
  hpMonitorTimer = nil
  --print("[HP Monitor] 已停止")
end
{$asm}
</AssemblerScript>
