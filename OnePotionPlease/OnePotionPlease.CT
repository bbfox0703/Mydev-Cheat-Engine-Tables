<?xml version="1.0" encoding="utf-8"?>
<CheatTable CheatEngineTableVersion="51">
  <CheatEntries>
    <CheatEntry>
      <ID>2</ID>
      <Description>"Proxy DLL winmm.dll must be installed in game folder before game running!"</Description>
      <Color>8000FF</Color>
      <GroupHeader>1</GroupHeader>
    </CheatEntry>
    <CheatEntry>
      <ID>3</ID>
      <Description>"Enable after game save 100% loded"</Description>
      <Options moHideChildren="1" moDeactivateChildrenAsWell="1"/>
      <GroupHeader>1</GroupHeader>
      <CheatEntries>
        <CheatEntry>
          <ID>0</ID>
          <Description>"ZoltDump: Main.JarMoney"</Description>
          <Options moHideChildren="1" moDeactivateChildrenAsWell="1"/>
          <VariableType>Auto Assembler Script</VariableType>
          <AssemblerScript>[ENABLE]
{$lua}
-- ZoltDump: Resolve 'Main.JarMoney' via proxy DLL mailbox
-- Two-step: FIND_NODE → GET_MEMBER_ADDR (survives game restarts)
-- Generated by ZoltDumpUI

if syntaxcheck then return end

local mb = getAddress('g_zoltMailbox')
if mb == 0 or mb == nil then
  print('[ZoltDump] ERROR: g_zoltMailbox not found — proxy DLL not loaded')
  error('ZoltDumper proxy DLL not loaded')
end

-- Wait for DLL init (STATUS_INIT = 0xFF)
for i = 1, 300 do  -- 30 second timeout
  if readInteger(mb + 0x4) ~= 0xFF then break end
  sleep(100)
end
if readInteger(mb + 0x4) == 0xFF then
  error('ZoltDumper DLL init timeout')
end

-- ═══ Step 1: Find node by name ═══
writeString(mb + 0x228, 'Main')
writeByte(mb + 0x228 + 4, 0)
writeQword(mb + 0x10, 0)  -- clear previous
-- Reset status before triggering (avoid stale DONE from previous command)
writeInteger(mb + 0x4, 0)
writeInteger(mb + 0x8, 0)  -- clear previous error
writeInteger(mb + 0x0, 3)  -- trigger FIND_NODE

-- Poll for FIND_NODE completion (5 second timeout)
for i = 1, 500 do
  if readInteger(mb + 0x4) == 1 then break end
  sleep(10)
end

if readInteger(mb + 0x4) ~= 1 then
  error('[ZoltDump] FIND_NODE timeout')
end

if readInteger(mb + 0x8) ~= 0 then
  local errMsg = readString(mb + 0x328, 256)
  print('[ZoltDump] ERROR: ' .. errMsg)
  error(errMsg)
end

local objAddr = readQword(mb + 0x10)
if objAddr == 0 then
  error('[ZoltDump] Node \'Main\' not found in scene tree')
end
print(string.format('[ZoltDump] Found node \'Main\' @ %X', objAddr))

-- ═══ Step 2: Resolve member address ═══
-- objectAddr is already set from Step 1 (DLL keeps it)
writeString(mb + 0x128, 'JarMoney')
writeByte(mb + 0x128 + 8, 0)
writeQword(mb + 0x18, 0)  -- clear previous
-- Reset status before triggering (avoid stale DONE from previous command)
writeInteger(mb + 0x4, 0)
writeInteger(mb + 0x8, 0)  -- clear previous error
writeInteger(mb + 0x0, 2)  -- trigger GET_MEMBER_ADDR

-- Poll for GET_MEMBER_ADDR completion (5 second timeout)
for i = 1, 500 do
  if readInteger(mb + 0x4) == 1 then break end
  sleep(10)
end

if readInteger(mb + 0x4) ~= 1 then
  error('[ZoltDump] GET_MEMBER_ADDR timeout')
end

if readInteger(mb + 0x8) ~= 0 then
  local errMsg = readString(mb + 0x328, 256)
  print('[ZoltDump] ERROR: ' .. errMsg)
  error(errMsg)
end

local addr = readQword(mb + 0x18)
if addr ~= 0 then
  unregisterSymbol('Main_JarMoney')
  registerSymbol('Main_JarMoney', addr)
  print(string.format('[ZoltDump] Main_JarMoney = %X', addr))
else
  print('[ZoltDump] WARNING: JarMoney address is 0')
end

[DISABLE]
{$lua}
if syntaxcheck then return end
unregisterSymbol('Main_JarMoney')
print('[ZoltDump] Main_JarMoney symbol removed')

</AssemblerScript>
