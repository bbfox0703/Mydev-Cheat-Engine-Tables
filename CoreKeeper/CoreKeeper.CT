label(code)
label(return)
label(i_base_hp_addr)
label(is_keep_hp)

newmem:
  mov [i_base_hp_addr], rax
  cmp dword ptr [is_keep_hp], 1
  jne code
  push r15
  mov r15d, [rax]
  cmp r15d, 64
  jle fill_hp
  cmp r15d, #2000
  jge fill_hp
  cmp r15d, [i_high_water_mark_hp]
  jg overwrite_rec
  jl fill_hp
  jmp endp

overwrite_rec:
  mov [i_high_water_mark_hp], r15d
  jmp endp

fill_hp:
  mov r15d, [i_high_water_mark_hp]
  mov [rax], r15d

endp:
  pop r15


code:
  cmp dword ptr [rax],00
  jle INJECT_GET_HP+88 // 7C + 5 + 7
  jmp return
align 10 cc
  i_base_hp_addr:
  dq 0
  is_keep_hp:
  dd 1
  i_high_water_mark_hp:
  dd C8

INJECT_GET_HP+7:
  jmp newmem
return:
