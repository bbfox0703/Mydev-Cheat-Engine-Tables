label(return)
label(is_full_hp)
label(is_full_mp)
label(is_min_en)

HPMP_SRCo:
  readmem(HPMP_SRC,$5)

newmem:
  push rbx                     // rax/rcx 都不能動，借 rbx
  cmp dword ptr [is_full_hp],1
  jne short @f
  mov ebx,[rax+44]             // lifeMax_ 的 float bits
  mov [rax+40],ebx             // life_ = lifeMax_
@@:
  cmp dword ptr [is_full_mp],1
  jne short @f
  mov ebx,[rax+4C]             // forceMax_ 的 float bits
  mov [rax+48],ebx             // force_ = forceMax_
@@:
  cmp dword ptr [is_min_en],1
  jne short @f
  movss xmm15, [vf_60]
  ucomiss xmm15, [rax+50]
  jbe short @F
  movss [rax+50],xmm15
@@:
  pop rbx

code:
  reassemble(HPMP_SRC)         // cvttss2si eax,[rax+40] (eax 會被重設，無妨)
  jmp return

  align 10 cc
  is_full_hp:
  dd 0
  is_full_mp:
  dd 0
  is_min_en:
  dd 0
  vf_60:
  dd (float)60

HPMP_SRC:
  jmp newmem
return:
registersymbol(HPMP_SRC)
registersymbol(HPMP_SRCo)
registersymbol(is_full_hp)
registersymbol(is_full_mp)
registersymbol(is_min_en)
[DISABLE]
HPMP_SRC:
  readmem(HPMP_SRCo,$5)
unregistersymbol(HPMP_SRC)
unregistersymbol(HPMP_SRCo)
unregistersymbol(is_full_hp)
unregistersymbol(is_full_mp)
unregistersymbol(is_min_en)
dealloc(newmem)
dealloc(HPMP_SRCo)

