  hook: cvttss2si eax,[rax+40] @ GameAssembly.dll+DDC12E
        (rax = CharacterData，已過 test rax/je)
  life_  = lifeMax_  (0x40 &lt;- 0x44)
  force_ = forceMax_ (0x48 &lt;- 0x4C)
  energy = 0x50
}

