end

local parentName = '+Control .NET managed +0x84 [+0x8C==1] (do not delete this)'
local prefix = 'Control_managed_0x84'
local addressList = getAddressList()

-- Remove symbols
for i = 1, 256 do
  pcall(function() unregisterSymbol(string.format('%s_%d', prefix, i)) end)
end

-- Remove all child memory records under the parent group
synchronize(function()
  local parentRecord = addressList.getMemoryRecordByDescription(parentName)
  if parentRecord then
    for i = addressList.Count - 1, 0, -1 do
      local child = addressList[i]
      if child.Parent == parentRecord then
        child.delete()
      end
    end
  end
end)
print('[ZoltDump] All Control_managed_0x84_* records removed')
closeLuaEngine()

